<%- include('partials/header') %>
<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="w-full bg-[#f8fafc] py-8 px-2 md:px-4 min-h-[80vh] font-sans">
  <div class="max-w-4xl mx-auto"> <!-- Rokomari স্টাইল সেন্ট্রাল ফোকাসড লেআউট -->
    
    <!-- Title Section -->
    <div class="border-b-2 border-slate-950 pb-2 mb-6 flex items-baseline justify-between">
      <h1 class="text-xl font-black text-slate-950 tracking-wider uppercase flex items-center gap-2">
        <span class="w-1.5 h-4 bg-orange-600 block"></span> Search Products
      </h1>
      <span id="result-count" class="text-[9px] text-slate-400 font-mono tracking-widest uppercase">Initializing...</span>
    </div>

    <!-- 🔍 Rokomari Style Core Search System -->
    <div class="relative w-full mb-8">
      <div class="flex items-center bg-white border-2 border-slate-950 rounded shadow-sm focus-within:border-orange-500 transition-colors">
        <!-- ইন্টেলিজেন্ট ইনপুট ফিল্ড -->
        <input
          type="text"
          id="search-input"
          placeholder="What are you looking for today? (e.g. ID card, Mug, T-Shirt)..."
          disabled
          autocomplete="off"
          class="w-full text-sm font-medium py-3 px-4 text-slate-800 bg-transparent placeholder-slate-400 focus:outline-none disabled:opacity-50"
        >
        <!-- সার্চ অ্যাকশন বাটন -->
        <button id="search-action-btn" class="bg-slate-950 hover:bg-orange-600 text-white text-xs font-mono font-bold uppercase tracking-wider px-6 py-3.5 transition-colors cursor-pointer rounded-r-sm h-full">
          Search
        </button>
      </div>

      <!-- ⚡ Live Floating Suggestions Box -->
      <div id="search-suggestions" class="absolute left-0 right-0 top-full mt-1 bg-white border border-slate-200 rounded shadow-xl hidden z-50 max-h-96 overflow-y-auto divide-y divide-slate-100"></div>
    </div>

    <!-- State Views -->
    <div id="search-status" class="text-center py-12 bg-white border border-slate-100 mb-6 hidden">
      <div id="status-spinner" class="w-5 h-5 border-2 border-orange-600 border-t-transparent rounded-full animate-spin mx-auto"></div>
      <p id="status-text" class="text-xs font-mono text-slate-400 uppercase tracking-wider mt-2"></p>
    </div>

    <!-- Main Results Dynamic Grid -->
    <div id="search-results-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3"></div>

  </div>
</div>

<%- include('partials/footer') %>

<script type="text/javascript">
  document.addEventListener('DOMContentLoaded', () => {
    const sInput = document.querySelector('#search-input'),
          sActionBtn = document.querySelector('#search-action-btn'),
          sSuggestions = document.querySelector('#search-suggestions'),
          rGrid = document.querySelector('#search-results-grid'),
          rCount = document.querySelector('#result-count'),
          sStatus = document.querySelector('#search-status'),
          sSpinner = document.querySelector('#status-spinner'),
          sText = document.querySelector('#status-text');

    let allProducts = [], filteredData = [];

    // ১. প্রোডাক্ট ডেটা ফেচ
    async function initInventory() {
      try {
        const response = await fetch('/products/api/all-raw');
        allProducts = await response.json();
        sInput.removeAttribute('disabled');
        rCount.innerText = "Ready to Search";
      } catch (err) {
        console.error(err);
        showStatus("⚠️ Failed to load store inventory.", true);
      }
    }

    // স্টেট ও স্ট্যাটাস ম্যানেজার
    function showStatus(msg, hideSpinner = false) {
      sStatus.classList.remove('hidden');
      sSpinner.classList.toggle('hidden', hideSpinner);
      sText.innerText = msg;
    }

    // ইমেজ সেফগার্ড হেল্পার
    const getImg = p => (p.images && p.images[0]) || p.image || p.img || 'https://via.placeholder.com/300';

    // লাইভ ড্রপডাউন সাজেশন জেনারেটর (Rokomari Style)
    sInput.addEventListener('input', () => {
      const val = sInput.value.trim().toLowerCase();
      if (!val) { return sSuggestions.classList.add('hidden'); }

      filteredData = allProducts.filter(p => p.name.toLowerCase().includes(val) || (p.category && p.category.toLowerCase().includes(val)));
      
      if (filteredData.length === 0) {
        sSuggestions.innerHTML = `<div class="p-4 text-center text-xs text-slate-400 font-mono uppercase">No matching products found</div>`;
        sSuggestions.classList.remove('hidden');
        return;
      }

      sSuggestions.innerHTML = filteredData.slice(0, 6).map(p => {
        const cur = p.isDiscount && p.discountPrice ? p.discountPrice : (p.price || 250);
        return `
          <div class="p-3 flex items-center justify-between hover:bg-slate-50 transition-colors group cursor-pointer" data-id="${p._id}">
            <div class="flex items-center gap-3 select-trigger flex-grow">
              <img class="w-10 h-10 object-cover border border-slate-100 rounded" src="${getImg(p)}" alt="${p.name}">
              <div>
                <h4 class="text-xs font-bold text-slate-800 line-clamp-1 group-hover:text-orange-600 transition-colors">${p.name}</h4>
                <p class="text-[11px] font-black text-slate-900 mt-0.5">৳${cur}</p>
              </div>
            </div>
            <!-- ড্রপডাউন কুইক একশন বাটন -->
            <div class="flex gap-1 pl-2">
              <button data-id="${p._id}" data-name="${p.name}" data-price="${cur}" data-image="${getImg(p)}" class="add-btn text-[9px] font-mono font-bold bg-slate-100 hover:bg-slate-950 hover:text-white px-2 py-1.5 rounded-sm uppercase tracking-tight transition-all">+ Cart</button>
              <button data-id="${p._id}" data-name="${p.name}" data-price="${cur}" data-image="${getImg(p)}" class="order-btn text-[9px] font-mono font-bold bg-orange-500 hover:bg-orange-600 text-white px-2 py-1.5 rounded-sm uppercase tracking-tight transition-all">Order</button>
            </div>
          </div>`;
      }).join('');
      sSuggestions.classList.remove('hidden');
    });

    // সাজেশন বক্সে ক্লিক হ্যান্ডলিং (প্রোডাক্ট সিলেক্ট করা অথবা ডিরেক্ট বাটন ক্লিক)
    sSuggestions.addEventListener('click', e => {
      const btn = e.target.closest('.add-btn, .order-btn');
      if (btn) return handleCartAndOrder(btn);

      const trigger = e.target.closest('.select-trigger');
      if (trigger) {
        const parent = trigger.closest('[data-id]');
        sInput.value = parent.querySelector('h4').innerText;
        sSuggestions.classList.add('hidden');
        renderMainGrid();
      }
    });

    // ২. এন্টার কি বা সার্চ বাটনে ক্লিক করলে গ্রিডে ফাইনাল রেজাল্ট শো
    const triggerSearch = () => { sSuggestions.classList.add('hidden'); renderMainGrid(); };
    sActionBtn.addEventListener('click', triggerSearch);
    sInput.addEventListener('keypress', e => { if (e.key === 'Enter') triggerSearch(); });

    // ৩. ফাইনাল রেজাল্ট গ্রিড রেন্ডারার
    function renderMainGrid() {
      const val = sInput.value.trim().toLowerCase();
      if (!val) {
        rGrid.innerHTML = '';
        rCount.innerText = "Ready to Search";
        return sStatus.classList.add('hidden');
      }

      filteredData = allProducts.filter(p => p.name.toLowerCase().includes(val) || (p.category && p.category.toLowerCase().includes(val)));
      sStatus.classList.add('hidden');

      if (filteredData.length === 0) {
        rGrid.innerHTML = '';
        rCount.innerText = "0 Found";
        return showStatus("❌ No Products Found Matching Your Request", true);
      }

      rCount.innerText = `${filteredData.length} ${filteredData.length > 1 ? 'Matches' : 'Match'}`;

      rGrid.innerHTML = filteredData.map(p => {
        const orig = p.price || 250, cur = p.isDiscount && p.discountPrice ? p.discountPrice : orig;
        const pct = (p.isDiscount && orig > cur) ? Math.round(((orig - cur) / orig) * 100) : 0;

        return `
          <div class="bg-white flex flex-col justify-between group hover:-translate-y-1 hover:shadow-md transition-all duration-300 border border-slate-200 rounded-md overflow-hidden relative">
            <a href="/products/details/${p._id}" class="block aspect-square bg-slate-50 overflow-hidden relative border-b border-slate-100">
              <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" src="${getImg(p)}" alt="${p.name}">
              ${p.isNewArrival ? `<span class="absolute top-2 left-2 bg-slate-950 text-white font-mono text-[8px] font-bold uppercase px-1.5 py-0.5 tracking-wider">New</span>` : ''}
              ${pct ? `<span class="absolute top-2 right-2 bg-red-600 text-white font-mono text-[8px] font-bold uppercase px-1.5 py-0.5 tracking-wider">-${pct}%</span>` : ''}
            </a>
            <div class="p-3 flex-grow flex flex-col justify-between">
              <div>
                <a href="/products/details/${p._id}">
                  <h3 class="text-xs font-bold text-slate-800 line-clamp-1 group-hover:text-orange-600 transition-colors leading-tight">${p.name}</h3>
                </a>
              </div>
              <div class="mt-2 pt-2 border-t border-dashed border-slate-100">
                <div class="flex items-baseline gap-1.5 mb-2">
                  <span class="text-xs font-black text-slate-950">৳${cur}</span>
                  ${pct ? `<span class="text-[9px] text-slate-400 line-through">৳${orig}</span>` : ''}
                </div>
                <!-- জোড়া একশন বাটন -->
                <div class="grid grid-cols-2 gap-1.5">
                  <button data-id="${p._id}" data-name="${p.name}" data-price="${cur}" data-image="${getImg(p)}" class="add-btn w-full bg-slate-950 hover:bg-slate-800 text-white font-mono font-bold text-[9px] py-2 uppercase tracking-tight rounded-sm cursor-pointer transition-colors">+ Cart</button>
                  <button data-id="${p._id}" data-name="${p.name}" data-price="${cur}" data-image="${getImg(p)}" class="order-btn w-full bg-orange-500 hover:bg-orange-600 text-white font-mono font-bold text-[9px] py-2 uppercase tracking-tight rounded-sm cursor-pointer transition-colors">Order</button>
                </div>
              </div>
            </div>
          </div>`;
      }).join('');
    }

    // ৪. ইভেন্ট ডেলিগেশনের মাধ্যমে কার্ট এবং অর্ডার হ্যান্ডলার
    rGrid.addEventListener('click', e => {
      const btn = e.target.closest('.add-btn, .order-btn');
      if (btn) handleCartAndOrder(btn);
    });

    function handleCartAndOrder(btn) {
      const pData = { 
        id: btn.dataset.id, 
        name: btn.dataset.name, 
        price: parseFloat(btn.dataset.price), 
        image: btn.dataset.image, 
        quantity: 1 
      };

      if (btn.classList.contains('add-btn')) {
        // Add to Cart লজিক
        let cart = JSON.parse(localStorage.getItem('cart')) || [];
        const exist = cart.find(i => i.id === pData.id);
        exist ? exist.quantity++ : cart.push(pData);
        localStorage.setItem('cart', JSON.stringify(cart));

        window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { totalItems: cart.reduce((s, i) => s + i.quantity, 0) } }));

        Swal.fire({
          title: 'Added to Cart', text: pData.name, icon: 'success', toast: true, position: 'top-end',
          showConfirmButton: false, timer: 1500, background: '#0f172a', color: '#fff', iconColor: '#ea580c'
        });
      } else if (btn.classList.contains('order-btn')) {
        // Direct Order Now লজিক
        localStorage.setItem('direct_checkout_item', JSON.stringify(pData));
        window.location.href = '/checkout?direct=true';
      }
    }

    // পেজের বাইরে ক্লিক করলে সাজেশন ড্রপডাউন ক্লোজ করা
    document.addEventListener('click', e => {
      if (!sInput.contains(e.target) && !sSuggestions.contains(e.target)) sSuggestions.classList.add('hidden');
    });

    initInventory();
  });
</script>
