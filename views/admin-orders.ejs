<%- include('partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="min-h-screen bg-gradient-to-br
 from-slate-50 via-white to-slate-100 py-4 px-4">
  
    <a  href="/admin/dashboard" class="hover:text-blue-500 hover:underline
mb-5 block text-blue-600">Back to dashboard</a>
  
  <div class="max-w-7xl mx-auto">
    
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8 pb-4 border-b border-slate-200">
      <div class="flex items-center gap-3">
        <div class="w-1 h-8 bg-gradient-to-b from-orange-500 to-orange-600 rounded-full"></div>
        <h1 class="text-2xl font-bold text-slate-900">Order Pipeline</h1>
        <span class="text-[10px] bg-slate-100 text-slate-500 px-2 py-0.5 rounded-full font-mono">
          <span id="total-orders-count"><%= orders ? orders.length : 0 %></span> orders
        </span>
      </div>
      <div class="flex items-center gap-3 w-full sm:w-auto">
        <div class="relative flex-1 sm:flex-none">
          <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs"></i>
          <input id="order-search" type="text" placeholder="Search by phone..." 
            class="pl-9 pr-4 py-2 text-sm border border-slate-200 rounded-lg focus:border-orange-400 focus:ring-2 focus:ring-orange-200 outline-none transition-all w-full sm:w-64">
        </div>
      </div>
    </div>

    <!-- No Results -->
    <div id="no-results" class="hidden text-center py-16 bg-white rounded-2xl border-2 border-dashed border-slate-200 mb-6">
      <i class="fa-solid fa-search text-3xl text-slate-300 mb-3 block"></i>
      <p class="text-sm text-slate-400">No orders found for this phone number</p>
    </div>

    <!-- Orders Feed -->
    <div id="orders-feed" class="space-y-4">
      <% if (orders && orders.length > 0) { %>
        <% orders.forEach(order => { %>
          <div id="order-<%= order._id %>" data-phone="<%= order.phone %>" 
            class="order-card bg-white rounded-2xl p-6 border border-slate-200 shadow-sm hover:shadow-md transition-all duration-300">
            
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
              
              <!-- Left: Customer Info -->
              <div class="lg:col-span-4">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-[10px] font-bold px-3 py-1 rounded-full status-badge-<%= order._id %>
                    <%= order.status === 'Pending' ? 'bg-amber-100 text-amber-700' : '' %>
                    <%= order.status === 'Processing' ? 'bg-orange-100 text-orange-700' : '' %>
                    <%= order.status === 'Shipped' ? 'bg-blue-100 text-blue-700' : '' %>
                    <%= order.status === 'Delivered' ? 'bg-emerald-100 text-emerald-700' : '' %>">
                    <%= order.status %>
                  </span>
                  <span class="text-[10px] text-slate-400 font-mono">#<%= order.orderId %></span>
                </div>
                
                <h3 class="font-bold text-slate-900"><%= order.name %></h3>
                <p class="text-sm text-slate-600"><i class="fa-solid fa-phone text-slate-400 text-xs mr-1"></i> <%= order.phone %></p>
                <% if(order.email) { %>
                  <p class="text-xs text-slate-400"><i class="fa-regular fa-envelope mr-1"></i> <%= order.email %></p>
                <% } %>
                <div class="mt-3 text-xs text-slate-600 bg-slate-50 p-3 rounded-lg border border-slate-100">
                  <i class="fa-solid fa-location-dot text-slate-400 mr-1"></i> <%= order.address %>
                </div>
              </div>

              <!-- Center: Items -->
              <div class="lg:col-span-5 border-t lg:border-t-0 lg:border-x border-slate-100 pt-4 lg:pt-0 lg:px-6">
                <p class="text-[10px] text-slate-400 font-mono uppercase tracking-wider mb-3">Items</p>
                <div class="space-y-2 max-h-[140px] overflow-y-auto pr-2">
                  <% order.items.forEach(item => { %>
                    <div class="flex items-center justify-between text-sm">
                      <div class="flex items-center gap-2 flex-1 min-w-0">
                        <img src="<%= item.image %>" class="w-8 h-8 rounded border border-slate-200 object-cover flex-shrink-0">
                        <span class="truncate"><%= item.name %></span>
                      </div>
                      <span class="font-mono text-xs text-slate-600 flex-shrink-0 ml-2">×<%= item.quantity %></span>
                      <span class="font-mono font-bold text-sm flex-shrink-0 ml-3">৳<%= item.price * item.quantity %></span>
                    </div>
                  <% }) %>
                </div>
                <div class="flex justify-between items-center mt-3 pt-3 border-t border-slate-100">
                  <span class="text-[10px] text-slate-400 font-mono uppercase">Total</span>
                  <span class="font-bold text-orange-600">৳<%= order.totalAmount %></span>
                </div>
              </div>

              <!-- Right: Actions -->
              <div class="lg:col-span-3 flex flex-col gap-2">
                <p class="text-[10px] text-slate-400 font-mono uppercase tracking-wider text-center">Actions</p>
                
                <button onclick="updateStatus('<%= order._id %>','Processing')" 
                  class="status-btn-<%= order._id %> w-full text-xs font-bold py-2.5 rounded-lg transition-all
                  <%= order.status === 'Pending' ? 'bg-orange-500 hover:bg-orange-600 text-white shadow-sm' : 'bg-slate-100 text-slate-400 cursor-not-allowed' %>"
                  <%= order.status !== 'Pending' ? 'disabled' : '' %>>
                  <i class="fa-regular fa-circle-check mr-1"></i> Confirm
                </button>

                <button onclick="updateStatus('<%= order._id %>','Shipped')"
                  class="status-btn-<%= order._id %> w-full text-xs font-bold py-2.5 rounded-lg transition-all
                  <%= order.status === 'Processing' ? 'bg-slate-800 hover:bg-slate-900 text-white shadow-sm' : 'bg-slate-100 text-slate-400 cursor-not-allowed' %>"
                  <%= order.status !== 'Processing' ? 'disabled' : '' %>>
                  <i class="fa-solid fa-truck mr-1"></i> Ship
                </button>

                <button onclick="updateStatus('<%= order._id %>','Delivered')"
                  class="status-btn-<%= order._id %> w-full text-xs font-bold py-2.5 rounded-lg transition-all
                  <%= order.status === 'Shipped' ? 'bg-emerald-500 hover:bg-emerald-600 text-white shadow-sm' : 'bg-slate-100 text-slate-400 cursor-not-allowed' %>"
                  <%= order.status !== 'Shipped' ? 'disabled' : '' %>>
                  <i class="fa-solid fa-check mr-1"></i> Deliver
                </button>

                <button onclick="deleteOrder('<%= order._id %>')"
                  class="w-full text-xs font-bold py-1.5 rounded-lg text-red-500 hover:bg-red-50 transition-all border border-red-200 hover:border-red-400">
                  <i class="fa-regular fa-trash-can mr-1"></i> Delete
                </button>
              </div>

            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div id="empty-state" class="text-center py-20 bg-white rounded-2xl border-2 border-dashed border-slate-200">
          <i class="fa-regular fa-folder-open text-4xl text-slate-300 mb-3 block"></i>
          <p class="text-sm text-slate-400">No orders found</p>
        </div>
      <% } %>
    </div>

  </div>
</div>

<%- include('partials/footer') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Search
  const search = document.getElementById('order-search');
  const noResults = document.getElementById('no-results');
  
  search?.addEventListener('input', function() {
    const term = this.value.trim();
    const cards = document.querySelectorAll('.order-card');
    let visible = 0;
    
    cards.forEach(card => {
      const phone = card.dataset.phone || '';
      if(phone.includes(term)) {
        card.style.display = '';
        visible++;
      } else {
        card.style.display = 'none';
      }
    });
    
    noResults.classList.toggle('hidden', visible > 0 || cards.length === 0);
  });
});

// Update Status - No Page Reload
async function updateStatus(id, status) {
  try {
    const statusMap = {
      'Processing': { title: 'Confirm Order', icon: '📦' },
      'Shipped': { title: 'Ship Order', icon: '🚚' },
      'Delivered': { title: 'Mark as Delivered', icon: '✅' }
    };
    
    const { isConfirmed } = await Swal.fire({
      title: `${statusMap[status]?.icon || ''} ${statusMap[status]?.title || status}?`,
      text: `Change order status to ${status}`,
      icon: 'question',
      showCancelButton: true,
      confirmButtonText: 'Yes, proceed',
      cancelButtonText: 'Cancel',
      confirmButtonColor: '#f97316',
      cancelButtonColor: '#64748b'
    });
    
    if(!isConfirmed) return;
    
    Swal.fire({ 
      title: 'Updating...', 
      allowOutsideClick: false, 
      didOpen: () => Swal.showLoading() 
    });
    
    const res = await fetch('/admin/api/orders/update-status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ orderId: id, status })
    });
    
    const data = await res.json();
    if(!data.success) throw new Error(data.message);
    
    // Update UI without reload
    const card = document.getElementById(`order-${id}`);
    if(card) {
      // Update status badge
      const badge = card.querySelector(`.status-badge-${id}`);
      if(badge) {
        // Remove all status classes
        badge.className = `text-[10px] font-bold px-3 py-1 rounded-full status-badge-${id}`;
        badge.textContent = status;
        
        // Add appropriate class
        if(status === 'Processing') badge.classList.add('bg-orange-100', 'text-orange-700');
        else if(status === 'Shipped') badge.classList.add('bg-blue-100', 'text-blue-700');
        else if(status === 'Delivered') badge.classList.add('bg-emerald-100', 'text-emerald-700');
      }
      
      // Update all buttons for this order
      const buttons = card.querySelectorAll(`.status-btn-${id}`);
      buttons.forEach(btn => {
        btn.disabled = true;
        btn.className = `status-btn-${id} w-full text-xs font-bold py-2.5 rounded-lg transition-all bg-slate-100 text-slate-400 cursor-not-allowed`;
      });
      
      // Enable appropriate next button
      const nextStatus = status === 'Processing' ? 'Shipped' : status === 'Shipped' ? 'Delivered' : null;
      if(nextStatus) {
        const nextBtn = card.querySelector(`button[onclick*="${nextStatus}"]`);
        if(nextBtn) {
          nextBtn.disabled = false;
          if(nextStatus === 'Shipped') {
            nextBtn.className = `status-btn-${id} w-full text-xs font-bold py-2.5 rounded-lg transition-all bg-slate-800 hover:bg-slate-900 text-white shadow-sm`;
          } else if(nextStatus === 'Delivered') {
            nextBtn.className = `status-btn-${id} w-full text-xs font-bold py-2.5 rounded-lg transition-all bg-emerald-500 hover:bg-emerald-600 text-white shadow-sm`;
          }
        }
      }
      
      // Add success animation
      card.style.borderColor = '#f97316';
      card.style.borderWidth = '2px';
      setTimeout(() => {
        card.style.borderColor = '';
        card.style.borderWidth = '';
      }, 2000);
    }
    
    Swal.close();
    
    Swal.fire({
      icon: 'success',
      title: `Status updated to ${status}!`,
      toast: true,
      position: 'top-end',
      showConfirmButton: false,
      timer: 1500,
      background: '#0f172a',
      color: '#fff'
    });
    
  } catch(e) {
    Swal.fire('Error', e.message || 'Update failed', 'error');
  }
}

// Delete Order
async function deleteOrder(id) {
  try {
    const { isConfirmed } = await Swal.fire({
      title: 'Delete Order?',
      text: 'This action cannot be undone',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Delete',
      cancelButtonText: 'Cancel',
      confirmButtonColor: '#ef4444',
      cancelButtonColor: '#64748b'
    });
    
    if(!isConfirmed) return;
    
    Swal.fire({ 
      title: 'Deleting...', 
      allowOutsideClick: false, 
      didOpen: () => Swal.showLoading() 
    });
    
    const res = await fetch(`/admin/api/orders/delete/${id}`, { 
      method: 'DELETE' 
    });
    const data = await res.json();
    
    if(!data.success) throw new Error(data.message);
    
    Swal.close();
    
    const card = document.getElementById(`order-${id}`);
    if(card) {
      card.style.transform = 'scale(0.95)';
      card.style.opacity = '0';
      setTimeout(() => {
        card.remove();
        const remaining = document.querySelectorAll('.order-card').length;
        document.getElementById('total-orders-count').textContent = remaining;
        if(remaining === 0) {
          document.getElementById('orders-feed').innerHTML = `
            <div class="text-center py-20 bg-white rounded-2xl border-2 border-dashed border-slate-200">
              <i class="fa-regular fa-folder-open text-4xl text-slate-300 mb-3 block"></i>
              <p class="text-sm text-slate-400">No orders found</p>
            </div>`;
        }
      }, 300);
    }
    
    Swal.fire({
      icon: 'success',
      title: 'Order Deleted!',
      toast: true,
      position: 'top-end',
      showConfirmButton: false,
      timer: 1500,
      background: '#0f172a',
      color: '#fff'
    });
    
  } catch(e) {
    Swal.fire('Error', e.message || 'Delete failed', 'error');
  }
}
</script>