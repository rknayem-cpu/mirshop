<%- include('partials/header') %>
<!-- SweetAlert2 CDN (কার্ট নোটিফিকেশনের জন্য) -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="w-full bg-[#f8fafc] py-12 px-4 md:px-8 min-h-[85vh]">
  <div class="max-w-6xl mx-auto bg-white border border-slate-100 p-4 md:p-8 shadow-[1px_1px_0px_rgba(0,0,0,0.02)]">
    
    <!-- Back to store breadcrumb -->
    <div class="mb-8">
      <a href="/all" class="text-[10px] font-mono text-slate-400 uppercase tracking-widest hover:text-orange-600 transition-colors flex items-center gap-1.5">
        <i class="fa-solid fa-arrow-left-long"></i> Back To Collection
      </a>
    </div>

    <!-- Product Grid Container -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      
      <!-- Left Column: Image Gallery System -->
      <div class="flex flex-col gap-3">
        <!-- Main Hero Image Frame -->
        <div class="w-full aspect-square bg-slate-50 border border-slate-100 overflow-hidden relative group">
          <img 
            id="main-product-image" 
            src="<%= product.images && product.images.length > 0 ? product.images[0] : '/placeholder.jpg' %>" 
            alt="<%= product.name %>"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          >
          
          <!-- Badges -->
          <div class="absolute top-3 left-3 flex flex-col gap-1.5">
            <% if (product.isNewArrival) { %>
              <span class="bg-slate-950 text-white font-mono text-[9px] font-bold uppercase px-2 py-0.5 tracking-wider">New Arrival</span>
            <% } %>
            <% if (product.isDiscount && product.price > product.discountPrice) { %>
              <% const pct = Math.round(((product.price - product.discountPrice) / product.price) * 100); %>
              <span class="bg-red-600 text-white font-mono text-[9px] font-bold uppercase px-2 py-0.5 tracking-wider">Save <%= pct %>%</span>
            <% } %>
          </div>
        </div>

        <!-- Thumbnails List (যদি একাধিক ইমেজ থাকে) -->
        <% if (product.images && product.images.length > 1) { %>
          <div class="grid grid-cols-5 gap-2">
            <% product.images.forEach((img, index) => { %>
              <div class="aspect-square bg-slate-50 border <%= index === 0 ? 'border-orange-600' : 'border-slate-200' %> overflow-hidden cursor-pointer thumb-box transition-colors">
                <img src="<%= img %>" alt="preview" class="w-full h-full object-cover p-0.5">
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Right Column: Premium Meta & Details -->
      <div class="flex flex-col justify-between py-2">
        <div>
          <!-- Category Label -->
          <span class="text-[10px] text-orange-600 font-mono font-bold uppercase tracking-widest block mb-1">
            // <%= product.category %>
          </span>
          
          <!-- Product Title -->
          <h1 class="text-2xl md:text-3xl
           font-black text-slate-950
            tracking-tight leading-none mb-4 mt-4 uppercase">
            <%= product.name %>
          </h1>

          <!-- Price Engine -->
          <div class="flex items-baseline gap-3 mb-0
           border-b border-dashed border-slate-100 pb-4">
            <% if (product.isDiscount && product.discountPrice) { %>
              <span class="text-2xl font-black text-slate-950 tracking-tight">৳<%= product.discountPrice %></span>
              <span class="text-sm text-slate-400 line-through">৳<%= product.price %></span>
            <% } else { %>
              <span class="text-xl font-black text-slate-800
               tracking-tight">৳<%= product.price %></span>
            <% } %>
          </div>

          <!-- Product Bio / Short Intro -->

          <!-- Product Main Long Description -->
          <div class="text-sm text-slate-600 font-normal leading-relaxed mb-8 prose">
            <p><%= product.bio || 'No detailed description available for this item.' %></p>
          </div>
        </div>

        <!-- Action / Add to Cart Block -->
        <div class="bg-slate-50 border border-slate-100 p-4 flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
          <!-- Quantity Counter Component -->
          <div class="flex items-center border border-slate-200 bg-white">
            <button id="qty-minus" class="px-3 py-2 text-slate-500 hover:bg-slate-50 font-mono transition-colors text-xs">-</button>
            <input id="qty-input" type="number" value="1" min="1" class="w-12 text-center text-xs font-bold font-mono border-none focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
            <button id="qty-plus" class="px-3 py-2 text-slate-500 hover:bg-slate-50 font-mono transition-colors text-xs">+</button>
          </div>

          <!-- Add to Cart Button -->
          <button 
            id="add-to-cart-action"
            data-id="<%= product._id %>"
            data-name="<%= product.name %>"
            data-price="<%= (product.isDiscount && product.discountPrice) ? product.discountPrice : product.price %>"
            data-image="<%= product.images && product.images.length > 0 ? product.images[0] : '/placeholder.jpg' %>"
            class="flex-grow bg-slate-950 hover:bg-orange-600 text-white font-mono font-bold text-xs py-3 uppercase tracking-widest transition-colors duration-300 flex items-center justify-center gap-2"
          >
            <i class="fa-solid fa-basket-shopping text-xs"></i> Add To Basket
          </button>
        </div>

      </div>

    </div>

  </div>
</div>

<%- include('partials/header') %>

<script type="text/javascript">
  document.addEventListener('DOMContentLoaded', () => {
    // ১. থাম্বনেইল গ্যালারি কন্ট্রোল লজিক
    const mainImg = document.getElementById('main-product-image');
    const thumbs = document.querySelectorAll('.thumb-box');

    thumbs.forEach(thumb => {
      thumb.addEventListener('click', function() {
        // আগের একটিভ ক্লাস রিমুভ করা
        thumbs.forEach(t => t.classList.remove('border-orange-600'));
        thumbs.forEach(t => t.classList.add('border-slate-200'));
        
        // বর্তমান থাম্বনেইল হাইলাইট
        this.classList.remove('border-slate-200');
        this.classList.add('border-orange-600');
        
        // মেইন ইমেজ চেঞ্জ
        const targetSrc = this.querySelector('img').getAttribute('src');
        mainImg.setAttribute('src', targetSrc);
      });
    });

    // ২. কোয়ান্টিটি কাউন্টার কাউন্ট লজিক
    const qtyInput = document.getElementById('qty-input');
    const qtyMinus = document.getElementById('qty-minus');
    const qtyPlus = document.getElementById('qty-plus');

    qtyMinus.addEventListener('click', () => {
      let val = parseInt(qtyInput.value);
      if(val > 1) qtyInput.value = val - 1;
    });

    qtyPlus.addEventListener('click', () => {
      let val = parseInt(qtyInput.value);
      qtyInput.value = val + 1;
    });

    // ৩. রিয়েল কার্ট মেকানিজম (LocalStorage ইন্টারফেস)
    const cartBtn = document.getElementById('add-to-cart-action');
    
    cartBtn.addEventListener('click', () => {
      const quantityToAdd = parseInt(qtyInput.value) || 1;
      
      const productObj = {
        id: cartBtn.dataset.id,
        name: cartBtn.dataset.name,
        price: parseFloat(cartBtn.dataset.price),
        image: cartBtn.dataset.image,
        quantity: quantityToAdd
      };

      // লোকাল স্টোরেজ থেকে কার্ট অ্যারে আনা বা নতুন তৈরি করা
      let cart = JSON.parse(localStorage.getItem('cart')) || [];
      
      // প্রোডাক্ট আগে থেকেই কার্টে আছে কিনা দেখা
      const existingItem = cart.find(item => item.id === productObj.id);
      
      if (existingItem) {
        existingItem.quantity += quantityToAdd;
      } else {
        cart.push(productObj);
      }

      // আপডেট করা কার্ট সেভ করা
      localStorage.setItem('cart', JSON.stringify(cart));

      // গ্লোবাল কার্ট কাউন্ট আপডেট ইভেন্ট ট্রিগার করা (হেডারের জন্য)
      const totalCount = cart.reduce((sum, item) => sum + item.quantity, 0);
      window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { totalItems: totalCount } }));

      // প্রিমিয়াম সুইট অ্যালার্ট টোস্ট নোটিফিকেশন
      Swal.fire({
        title: 'Basket Updated',
        text: `${quantityToAdd}x ${productObj.name} added.`,
        icon: 'success',
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 1800,
        background: '#0f172a',
        color: '#fff',
        iconColor: '#ea580c'
      });
    });
  });
</script>
