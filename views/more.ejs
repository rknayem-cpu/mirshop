<%- include('partials/header') %>

<div class="w-full bg-[#f8fafc] py-16 px-4 min-h-screen flex flex-col items-center justify-center">
  <div class="w-full max-w-2xl">

    <!-- 🌐 Hub Header -->
    <div class="text-center mb-10">
      <h1 class="text-3xl font-black text-slate-950 tracking-wider uppercase inline-flex items-center gap-3">
        <span class="w-3 h-7 bg-orange-600 block transform -skew-x-12"></span> Mir Shop Terminal
      </h1>
      <p class="text-xs font-mono text-slate-400 uppercase tracking-widest mt-2">// core services, trust metrics & customer support</p>
    </div>

    <!-- 📊 Core Features Grid (Vertical Flow) -->
    <div class="space-y-5 mb-8">
      
      <!-- ⚡ Fast Delivery Card -->
      <div class="bg-white border-2 border-slate-950 p-5 shadow-[4px_4px_0px_rgba(15,23,42,1)] relative overflow-hidden group hover:-translate-y-0.5 transition-transform">
        <div class="absolute top-0 right-0 bg-orange-600 text-white font-mono text-[8px] font-black px-3 py-0.5 uppercase tracking-widest border-b-2 border-l-2 border-slate-950">
          LOGISTICS_NODE
        </div>
        <h2 class="text-sm font-black text-slate-950 uppercase tracking-wide mb-1.5 flex items-center gap-2">
          <i class="fa-solid fa-bolt text-orange-600"></i> সুপার ফাস্ট ডেলিভারি
        </h2>
        <p class="text-xs text-slate-600 font-sans leading-relaxed">
          আপনার অর্ডার কনফার্ম হওয়ার পর আমরা সবচেয়ে দ্রুততম সময়ে ডেলিভারি নিশ্চিত করি। ঢাকা সিটির ভেতর মাত্র ২৪ থেকে ৪৮ ঘণ্টার মধ্যে এবং ঢাকার বাইরে সর্বোচ্চ ৩ দিনের মধ্যে আপনার পার্সেল পৌঁছে যাবে আপনার দরজায়।
        </p>
      </div>

      <!-- 🔄 Easy Return Card -->
      <div class="bg-white border-2 border-slate-950 p-5 shadow-[4px_4px_0px_rgba(15,23,42,1)] relative overflow-hidden group hover:-translate-y-0.5 transition-transform">
        <div class="absolute top-0 right-0 bg-emerald-500 text-slate-950 font-mono text-[8px] font-black px-3 py-0.5 uppercase tracking-widest border-b-2 border-l-2 border-slate-950">
          RETURN_SYS
        </div>
        <h2 class="text-sm font-black text-slate-950 uppercase tracking-wide mb-1.5 flex items-center gap-2">
          <i class="fa-solid fa-arrow-rotate-left text-emerald-600"></i> ১০০% সহজ রিটার্ন পলিসি
        </h2>
        <p class="text-xs text-slate-600 font-sans leading-relaxed">
          প্রোডাক্টে কোনো সমস্যা বা ত্রুটি থাকলে একদম চিন্তা করবেন না। ডেলিভারি পাওয়ার পর যেকোনো যৌক্তিক কারণে আপনি প্রোডাক্টটি সহজে রিটার্ন বা এক্সচেঞ্জ করতে পারবেন। আমাদের কাস্টমার ফ্রেন্ডলি পলিসি আপনার কেনাকাটাকে করবে সম্পূর্ণ ঝুঁকিমুক্ত।
        </p>
      </div>

      <!-- 🤝 Trusted Business Card -->
      <div class="bg-white border-2 border-slate-950 p-5 shadow-[4px_4px_0px_rgba(15,23,42,1)] relative overflow-hidden group hover:-translate-y-0.5 transition-transform">
        <div class="absolute top-0 right-0 bg-blue-500 text-white font-mono text-[8px] font-black px-3 py-0.5 uppercase tracking-widest border-b-2 border-l-2 border-slate-950">
          TRUST_VERIFIED
        </div>
        <h2 class="text-sm font-black text-slate-950 uppercase tracking-wide mb-1.5 flex items-center gap-2">
          <i class="fa-solid fa-shield-halved text-blue-600"></i> বিশ্বস্ত কেনাকাটার নিশ্চয়তা
        </h2>
        <p class="text-xs text-slate-600 font-sans leading-relaxed">
          Mir Shop-এ আমরা কোয়ালিটি এবং কাস্টমার স্যাটিসফ্যাকশনকে সবচেয়ে বেশি প্রাধান্য দিই। জেনুইন প্রোডাক্ট, নিরাপদ পেমেন্ট গেটওয়ে এবং স্বচ্ছ ডিলিংয়ের মাধ্যমে আমরা অর্জন করেছি হাজারো ক্রেতার অবিচল আস্থা ও বিশ্বাস।
        </p>
      </div>

    </div>

    <!-- 🛠️ Help & Support Action Center -->
    <div class="bg-amber-50 border-2 border-slate-950 p-6 shadow-[5px_5px_0px_rgba(15,23,42,1)] text-center">
      <span class="text-[9px] font-mono text-slate-400 block uppercase tracking-widest mb-2">// Communications Pipeline</span>
      <h3 class="text-base font-black text-slate-950 uppercase tracking-wide mb-2">কোনো সাহায্য লাগবে?</h3>
      <p class="text-xs font-sans text-slate-700 max-w-md mx-auto mb-5 leading-relaxed">
        আপনার অর্ডার, ডেলিভারি কিংবা অন্য যেকোনো জিজ্ঞাসা থাকলে আমাদের সাপোর্ট টিম সবসময় প্রস্তুত। নিচের বাটনে ক্লিক করে সরাসরি আমাদের সাথে যোগাযোগ করুন।
      </p>
      
      <!-- 📞 Heavy Styled Help & Support Button -->
      <a 
        href="tel:01884405184" 
        
        class="inline-flex items-center justify-center gap-2 w-full sm:w-auto bg-slate-950 hover:bg-slate-900 text-white font-mono text-xs font-black px-8 py-3.5 uppercase tracking-widest transition-all border-2 border-slate-950 shadow-[3px_3px_0px_rgba(234,88,12,1)] active:translate-y-0.5 active:shadow-none"
      >
        <i class="fa-solid fa-headset text-orange-500 text-sm"></i> Help & Support Center
      </a>
    </div>

    <!-- 📜 Footer Stamp -->
    <div class="text-center mt-12">
      <p class="text-[9px] font-mono text-slate-400 uppercase tracking-widest">Mir Shop Core Infrastructure © 2026 // All Nodes Operational</p>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
