<%- include('partials/header') %>

<div class="min-h-screen bg-gradient-to-br
 from-slate-50 via-white to-orange-50/30 py-10
  px-3 flex items-center justify-center">
  <div class="w-full max-w-3xl">
    
    <!-- Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-3 bg-white px-6 py-3 rounded-2xl shadow-sm border border-slate-100">
        <span class="w-3 h-8 bg-gradient-to-b from-orange-500 to-orange-600 rounded-full"></span>
        <h1 class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight">Mir Shop Terminal</h1>
      </div>
      <p class="text-xs text-slate-400 font-mono uppercase tracking-widest mt-3 flex items-center justify-center gap-2">
        <span class="w-8 h-px bg-slate-200"></span>
        core services & customer support
        <span class="w-8 h-px bg-slate-200"></span>
      </p>
    </div>

    <!-- Feature Cards -->
    <div class="grid gap-5 mb-8">
      
      <!-- Fast Delivery -->
      <div class="group bg-white rounded-2xl p-6 border border-slate-200 shadow-sm hover:shadow-xl hover:shadow-orange-500/5 hover:border-orange-200 transition-all duration-300 relative overflow-hidden">
        <div class="absolute top-0 right-0 bg-gradient-to-l from-orange-500 to-orange-400 text-white text-[8px] font-bold px-4 py-1 rounded-bl-xl rounded-tr-2xl uppercase tracking-wider flex items-center gap-1.5">
          <i class="fa-solid fa-bolt text-[10px]"></i>
          Logistics
        </div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-orange-100 to-orange-200 flex items-center justify-center text-orange-600 text-xl shrink-0 group-hover:scale-110 transition-transform">
            <i class="fa-solid fa-truck-fast"></i>
          </div>
          <div>
            <h3 class="text-base font-bold text-slate-900 mb-1 flex items-center gap-2">
              সুপার ফাস্ট ডেলিভারি
              <span class="text-[8px] bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full font-mono">24-48hrs</span>
            </h3>
            <p class="text-sm text-slate-600 leading-relaxed">
              ঢাকার ভেতর ২৪-৪৮ ঘণ্টায় এবং ঢাকার বাইরে সর্বোচ্চ ৩ দিনের মধ্যে আপনার পার্সেল পৌঁছে যাবে আপনার দরজায়।
            </p>
          </div>
        </div>
      </div>

      <!-- Easy Return -->
      <div class="group bg-white rounded-2xl p-6 border border-slate-200 shadow-sm hover:shadow-xl hover:shadow-emerald-500/5 hover:border-emerald-200 transition-all duration-300 relative overflow-hidden">
        <div class="absolute top-0 right-0 bg-gradient-to-l from-emerald-500 to-emerald-400 text-white text-[8px] font-bold px-4 py-1 rounded-bl-xl rounded-tr-2xl uppercase tracking-wider flex items-center gap-1.5">
          <i class="fa-solid fa-rotate-left text-[10px]"></i>
          Return
        </div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-emerald-100 to-emerald-200 flex items-center justify-center text-emerald-600 text-xl shrink-0 group-hover:scale-110 transition-transform">
            <i class="fa-solid fa-arrow-rotate-left"></i>
          </div>
          <div>
            <h3 class="text-base font-bold text-slate-900 mb-1">১০০% সহজ রিটার্ন পলিসি</h3>
            <p class="text-sm text-slate-600 leading-relaxed">
              ডেলিভারি পাওয়ার পর যেকোনো যৌক্তিক কারণে প্রোডাক্ট সহজে রিটার্ন বা এক্সচেঞ্জ করুন। সম্পূর্ণ ঝুঁকিমুক্ত কেনাকাটা।
            </p>
          </div>
        </div>
      </div>

      <!-- Trusted Business -->
      <div class="group bg-white rounded-2xl p-6 border border-slate-200 shadow-sm hover:shadow-xl hover:shadow-blue-500/5 hover:border-blue-200 transition-all duration-300 relative overflow-hidden">
        <div class="absolute top-0 right-0 bg-gradient-to-l from-blue-500 to-blue-400 text-white text-[8px] font-bold px-4 py-1 rounded-bl-xl rounded-tr-2xl uppercase tracking-wider flex items-center gap-1.5">
          <i class="fa-solid fa-shield-halved text-[10px]"></i>
          Trust
        </div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-100 to-blue-200 flex items-center justify-center text-blue-600 text-xl shrink-0 group-hover:scale-110 transition-transform">
            <i class="fa-solid fa-handshake"></i>
          </div>
          <div>
            <h3 class="text-base font-bold text-slate-900 mb-1">বিশ্বস্ত কেনাকাটার নিশ্চয়তা</h3>
            <p class="text-sm text-slate-600 leading-relaxed">
              জেনুইন প্রোডাক্ট, নিরাপদ পেমেন্ট এবং স্বচ্ছ ডিলিংয়ের মাধ্যমে হাজারো ক্রেতার আস্থা অর্জন করেছি আমরা।
            </p>
          </div>
        </div>
      </div>

    </div>

    <!-- Support Center -->
    <div class="relative bg-gradient-to-br from-orange-50 via-amber-50 to-orange-100/50 rounded-2xl p-8 border border-orange-200 shadow-lg overflow-hidden">
      <!-- Decorative Elements -->
      <div class="absolute -top-10 -right-10 w-40 h-40 bg-orange-200/30 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-amber-200/30 rounded-full blur-3xl"></div>
      
      <div class="relative">
        <div class="flex items-center gap-2 text-xs text-orange-600 font-mono uppercase tracking-widest mb-2">
          <span class="w-6 h-px bg-orange-300"></span>
          Communications Pipeline
        </div>
        
        <h3 class="text-xl font-bold text-slate-900 mb-2">কোনো সাহায্য লাগবে?</h3>
        <p class="text-sm text-slate-600 max-w-md mb-6 leading-relaxed">
          অর্ডার, ডেলিভারি বা যেকোনো জিজ্ঞাসায় আমাদের সাপোর্ট টিম ২৪/৭ প্রস্তুত।
        </p>

        <!-- Support Buttons -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="tel:01884405184" 
             class="inline-flex items-center justify-center gap-2.5 flex-1 bg-slate-900 hover:bg-orange-600 text-white text-sm font-bold px-6 py-3.5 rounded-xl transition-all duration-300 shadow-lg shadow-slate-900/20 hover:shadow-orange-500/30 group">
            <i class="fa-solid fa-headset text-orange-400 group-hover:text-white transition-colors"></i>
            Call Support
            <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform text-xs"></i>
          </a>
          
          
        </div>
        
        <!-- Quick Stats -->
        <div class="flex flex-wrap gap-6 mt-6 pt-5 border-t border-orange-200/50">
          <div class="flex items-center gap-2 text-xs text-slate-500">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
            <span>Online Now</span>
          </div>
          <div class="flex items-center gap-2 text-xs text-slate-500">
            <i class="fa-regular fa-clock text-orange-500"></i>
            <span>24/7 Support</span>
          </div>
          <div class="flex items-center gap-2 text-xs text-slate-500">
            <i class="fa-regular fa-thumbs-up text-emerald-500"></i>
            <span>98% Satisfaction</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer Stamp -->
    <div class="text-center mt-10">
      <div class="inline-flex items-center gap-3 text-[9px] font-mono text-slate-400 uppercase tracking-widest">
        <span class="w-6 h-px bg-slate-200"></span>
        Mir Shop Core Infrastructure © 2026
        <span class="w-6 h-px bg-slate-200"></span>
      </div>
      <div class="flex items-center justify-center gap-4 mt-3 text-[10px] text-slate-400">
        <span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span> All Nodes Operational</span>
        <span class="flex items-center gap-1"><i class="fa-regular fa-heart text-rose-400"></i> Secure</span>
      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>