<%- include('partials/header') %>

<!-- 🔐 ADMIN LOGIN INTERFACE -->
<div class="w-full bg-[#f8fafc] min-h-[70vh] flex items-center justify-center py-12 px-4 font-sans text-slate-900">
  <div class="w-full max-w-sm bg-white border border-slate-200 rounded-md p-6 shadow-sm">
    
    <!-- Header/Title -->
    <div class="text-center mb-6">
      <div class="inline-flex items-center justify-center w-10 h-10 bg-slate-950 text-white font-black text-lg rounded mb-2 border-b-2 border-orange-600">
        M
      </div>
      <h1 class="text-sm font-bold uppercase tracking-wide text-slate-900">Admin Authentication</h1>
      <p class="text-[9px] text-slate-400 font-mono uppercase tracking-widest mt-0.5">// restricted area gateway</p>
    </div>

    <!-- Error/Alert Message Flash (যদি পাসওয়ার্ড ভুল হয়) -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-600 font-mono text-[10px] uppercase p-2.5 rounded mb-4 text-center tracking-wide">
        ❌ Invalid Admin Password!
      </div>
    <% } %>

    <!-- 📥 FORM PIPELINE -->
    <form action="/admin-login" method="POST" class="space-y-4">
      <div>
        <label class="block text-[10px] font-mono font-bold uppercase text-slate-400 tracking-wider mb-1.5">
          Enter Security Password
        </label>
        <div class="relative">
          <input type="password" 
                 name="secretPassword" 
                 placeholder="••••••••" 
                 class="w-full bg-slate-50 border border-slate-300 rounded px-3 py-2 text-xs font-mono focus:outline-none focus:border-orange-600 transition-colors" 
                 required 
                 autofocus>
        </div>
      </div>

      <!-- Submit Action Button -->
      <button type="submit" class="w-full bg-slate-950 hover:bg-orange-600 text-white font-mono font-bold text-[10px] py-2.5 uppercase tracking-widest rounded transition-colors duration-200 shadow active:scale-[0.98]">
        Unlock Control Desk &rarr;
      </button>
    </form>

    <!-- Bottom Notice -->
    <div class="mt-6 pt-4 border-t border-slate-100 text-center">
      <a href="/all" class="text-[9px] font-mono font-bold text-slate-400 hover:text-slate-600 uppercase tracking-wider">
        &larr; Return to Public Store
      </a>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
