<%- include('partials/header') %>
<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="w-full bg-[#f8fafc] py-8 px-2 md:px-4">
  <div class="max-w-7xl mx-auto">
    
    <!-- Title Section -->
    <div class="border-b-2 border-slate-950 pb-2 mb-6 flex items-baseline justify-between">
      <h1 class="text-xl font-black text-slate-950 tracking-wider uppercase flex items-center gap-2">
        <span class="w-1.5 h-4 bg-orange-600 block"></span> Infinite Shop
      </h1>
      <span class="text-[9px] text-slate-400 font-mono tracking-widest uppercase">New Drop</span>
    </div>

    <!-- Responsive Modern Grid (গ্যাপ কমিয়ে টাইট ও মডার্ন করা) -->
    <div id="product-grid" class="grid grid-cols-2 
    
    
    sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 p-1"></div>

    <!-- Modern Animated Loader Trigger -->
    <div id="load-trigger" class="flex justify-center items-center py-8 text-[10px] font-mono tracking-widest text-slate-400 uppercase">
      <span>Loading Goods</span>
      <div class="ml-2 w-3 h-3 border-2 border-orange-600 border-t-transparent rounded-full animate-spin"></div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>

<script type="text/javascript">
  const limit = 10;
  let skip = 0, isLoading = false, hasMore = true;
  const grid = document.querySelector('#product-grid'), trigger = document.querySelector('#load-trigger');

  // ১. ডাইনামিক ফেচ ও প্রিমিয়াম মডার্ন কার্ড জেনারেশন (Ultra-Stylish & Clean)
  async function loadProducts() {
    if (isLoading || !hasMore) return;
    isLoading = true;
    try {
      const res = await fetch(`/products/api/load-infinite?skip=${skip}&limit=${limit}`);
      const data = await res.json();
      
      if (!data.length) {
        hasMore = false;
        trigger.innerHTML = "🎉 Collection Complete";
        return;
      }

      grid.insertAdjacentHTML('beforeend', data.map(p => {
        const orig = p.price || 250, cur = p.isDiscount && p.discountPrice ? p.discountPrice : orig;
        const pct = (p.isDiscount && orig > cur) ? Math.round(((orig - cur) / orig) * 100) : 0;
        
        return `
          <div class="bg-white flex flex-col 
          justify-between group overflow-hidden
           hover:-translate-y-1 hover:shadow-lg
           shadow-xl 
           transition-all duration-300
            relative  rounded-md">
            
            <!-- Image Frame (গ্লসি ওভারলে ও জুম ইফেক্ট) -->
            <a href="/products/details/${p._id}" class="block aspect-square bg-slate-50 overflow-hidden relative border-b border-slate-100/60">
              <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" src="${p.images[0]}" alt="${p.name}">
              
              <!-- ব্যাজ ডিজাইন (শার্প ও বোল্ড) -->
              ${p.isNewArrival ? `<span class="absolute top-2 left-2 bg-slate-950 text-white font-mono text-[8px] font-bold uppercase px-1.5 py-0.5 tracking-wider">New</span>` : ''}
              ${pct ? `<span class="absolute top-2
               right-2 bg-red-600 text-white 
               font-mono text-[8px] font-bold 
               uppercase px-1.5 py-0.5 tracking-wider">-${pct}%</span>` : ''}
            </a>

            <!-- Content Frame -->
            <div class="p-3 flex-grow flex flex-col
             justify-between">
              <div>
                <span class="text-[9px] 
                text-white rounded-md font-mono 
                uppercase tracking-widest block p-1 w-fit
                 mb-0.5 bg-green-700">${p.category}</span>
                <a href="/products/details/${p._id}">
                  <h3 class="text-xs 
                  font-bold text-slate-800 
                  line-clamp-1 mt-3
                   group-hover:text-orange-600
                    transition-colors duration-200 
                    leading-tight">${p.name}</h3>
                </a>
              
              
              
              </div>

              <!-- Price & Button (বর্ডারলেস হাই-কনট্রাস্ট ফিনিশিং) -->
              <div class="mt-0 pt-2 border-t border-dashed border-slate-100">
                <div class="flex items-baseline gap-1.5 mb-2">
                  <span class="text-xs font-black text-slate-950 tracking-tight">৳${cur}</span>
                  ${pct ? `<span class="text-[9px] text-slate-400 line-through">৳${orig}</span>` : ''}
                </div>
                <button data-id="${p._id}" data-name="${p.name}" data-price="${cur}" data-image="${p.images[0]}" class="add-btn w-full bg-slate-950 group-hover:bg-orange-600 text-white font-mono font-bold text-[9px] py-2 uppercase tracking-widest transition-colors duration-300">
                  + Add To Cart
                </button>
              </div>
            </div>

          </div>`;
      }).join(''));

      skip += limit;
      isLoading = false;
      if (document.documentElement.clientHeight >= document.documentElement.scrollHeight) loadProducts();
    } catch (err) { console.error(err); } finally { isLoading = false; }
  }

  // ২. কার্ট লজিক + কাস্টম ইভেন্ট + প্রিমিয়াম ডার্ক টোস্ট অ্যালার্ট
  grid.addEventListener('click', e => {
    if (!e.target.classList.contains('add-btn')) return;
    const b = e.target;
    const prod = { id: b.dataset.id, name: b.dataset.name, price: parseFloat(b.dataset.price), image: b.dataset.image, quantity: 1 };
    
    let cart = JSON.parse(localStorage.getItem('cart')) || [];
    const exist = cart.find(i => i.id === prod.id);
    exist ? exist.quantity++ : cart.push(prod);
    localStorage.setItem('cart', JSON.stringify(cart));

    window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { totalItems: cart.reduce((s, i) => s + i.quantity, 0) } }));

    // SweetAlert2 ওয়ান-লাইন কাস্টমাইজেশন (সুপার ক্লিন ও মডার্ন)
    Swal.fire({
      title: 'Added to Cart',
      text: prod.name,
      icon: 'success',
      toast: true,
      position: 'top-end',
      showConfirmButton: false,
      timer: 1500,
      background: '#0f172a',
      color: '#fff',
      iconColor: 'green'
    });
  });

  // ৩. ইনফিনিট স্ক্রল লিসেনার
  const observer = new IntersectionObserver(entries => { if (entries[0].isIntersecting) loadProducts(); }, { rootMargin: '100px' });
  observer.observe(trigger);
</script>
