<%- include('partials/header') %>

<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="w-full bg-gradient-to-b 
from-slate-50 to-white py-8 px-3 md:px-4">
  <div class="max-w-7xl mx-auto">

    <!-- Premium Header -->
    <div class="flex items-baseline justify-between border-b-2 border-slate-900 pb-3 mb-6">
      <h1 class="text-2xl font-black tracking-tight text-slate-900 flex items-center gap-2">
        <span class="w-2 h-6 bg-orange-500 rounded-full"></span> 
        <span class="bg-gradient-to-r from-slate-900 to-slate-600 bg-clip-text text-transparent">Infinite</span>
        <span class="text-orange-500">Shop</span>
      </h1>
      <span class="text-[10px] font-mono tracking-[0.2em] text-slate-400 bg-slate-100 px-3 py-1 rounded-full">New Drop</span>
    </div>

    <!-- Product Grid -->
    <div id="product-grid" class="grid grid-cols-2
     sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 
     gap-2 md:gap-4 min-h-[200px]"></div>

    <!-- Loader (Shows when loading more products) -->
    <div id="load-trigger" class="flex items-center justify-center gap-3 py-10 text-[11px] font-mono tracking-widest text-slate-400">
      <span class="uppercase">Loading More</span>
      <span class="w-4 h-4 border-2 border-orange-500 border-t-transparent rounded-full animate-spin"></span>
    </div>

  </div>
</div>

<%- include('partials/footer') %>

<script>
  const LIMIT = 10;
  let skip = 0, loading = false, more = true, initialLoad = true;
  const grid = document.querySelector('#product-grid');
  const trigger = document.querySelector('#load-trigger');

  // 🚀 Load Products
  async function loadProducts() {
    if (loading || !more) return;
    loading = true;
    
    // Show loader only for subsequent loads (not for initial)
    if (!initialLoad) {
      trigger.innerHTML = `<span class="uppercase">Loading More</span><span class="w-4 h-4 border-2 border-orange-500 border-t-transparent rounded-full animate-spin"></span>`;
    }

    try {
      const res = await fetch(`/products/api/load-infinite?skip=${skip}&limit=${LIMIT}`);
      const data = await res.json();

      if (!data?.length) {
        more = false;
        trigger.innerHTML = '✨ Collection Complete';
        return;
      }

      // Render Cards
      grid.insertAdjacentHTML('beforeend', data.map(p => {
        const price = p.discountPrice && p.isDiscount ? p.discountPrice : p.price;
        const discount = p.isDiscount && p.price > price ? Math.round(((p.price - price) / p.price) * 100) : 0;

        return `
          <div class="group bg-white rounded-lg
            hover:shadow-2xl hover:-translate-y-1
             transition-all duration-300
              overflow-hidden animate-fadeIn border border-slate-200">
            <a href="/products/details/${p._id}" class="block aspect-square bg-slate-100 relative">
              <img class="w-full h-full object-cover 
              group-hover:scale-105 
              transition duration-500" src="${p.images[0]}" alt="${p.name}" loading="lazy">
              ${p.isNewArrival ? `<span class="absolute top-2 left-2 bg-black text-white text-[8px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">New</span>` : ''}
              ${discount ? `<span class="absolute top-2 right-2 bg-red-500 text-white text-[8px] font-bold px-2 py-0.5 rounded-full">-${discount}%</span>` : ''}
            </a>
            <div class="p-3">
              <span class="text-[8px] font-mono uppercase tracking-widest text-white bg-emerald-700 px-2 py-0.5 rounded">${p.category}</span>
              <h3 class="text-xs font-bold text-slate-800 mt-1.5 truncate group-hover:text-orange-500 transition">${p.name}</h3>
              <div class="flex items-center gap-2 mt-1.5">
                <span class="text-sm font-black text-slate-900">৳${price}</span>
                ${discount ? `<span class="text-[10px] text-slate-400 line-through">৳${p.price}</span>` : ''}
              </div>
              <button data-id="${p._id}" data-name="${p.name}" data-price="${price}" data-image="${p.images[0]}" 
                class="add-btn w-full mt-2 bg-slate-900 
                hover:bg-orange-500 
                text-white text-[9px] font-bold py-2
                 uppercase rounded-sm  tracking-widest transition">
                + Add to cart
              </button>
            </div>
          </div>
        `;
      }).join(''));

      if (data.length < LIMIT) {
        more = false;
        trigger.innerHTML = '✨ Collection Complete';
      } else {
        skip += LIMIT;
        loading = false;
        initialLoad = false; // Mark initial load as done
        
        // Reset trigger for next load
        trigger.innerHTML = `<span class="uppercase">Loading More</span><span class="w-4 h-4 border-2 border-orange-500 border-t-transparent rounded-full animate-spin"></span>`;
        
        // Auto-load if screen has room
        setTimeout(() => {
          if (more && window.innerHeight >= document.documentElement.scrollHeight - 200) {
            loadProducts();
          }
        }, 300);
      }

    } catch (err) {
      console.error(err);
      loading = false;
      trigger.innerHTML = '⚠️ Error loading';
    }
  }

  // 🛒 Add to Cart
  grid.addEventListener('click', e => {
    const btn = e.target.closest('.add-btn');
    if (!btn) return;

    const item = {
      id: btn.dataset.id,
      name: btn.dataset.name,
      price: parseFloat(btn.dataset.price),
      image: btn.dataset.image,
      quantity: 1
    };

    let cart = JSON.parse(localStorage.getItem('cart') || '[]');
    const existing = cart.find(i => i.id === item.id);
    existing ? existing.quantity++ : cart.push(item);
    localStorage.setItem('cart', JSON.stringify(cart));

    window.dispatchEvent(new CustomEvent('cartUpdated', {
      detail: { totalItems: cart.reduce((sum, i) => sum + i.quantity, 0) }
    }));

    Swal.fire({
      icon: 'success',
      title: 'Added to cart',
      text: item.name,
      toast: true,
      position: 'top-end',
      showConfirmButton: false,
      timer: 1200,
      background: '#0f172a',
      color: 'white',
      iconColor: 'green'
    });
  });

  // 👁️ Infinite Scroll Observer
  const observer = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting && !loading && more && !initialLoad) {
      loadProducts();
    }
  }, { rootMargin: '150px' });
  
  observer.observe(trigger);

  // 🚀 INITIAL LOAD - Products appear immediately on page load
  loadProducts();

  // ✨ Add fade-in animation
  const style = document.createElement('style');
  style.textContent = `
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fadeIn {
      animation: fadeIn 0.5s ease-out forwards;
    }
  `;
  document.head.appendChild(style);
</script>
