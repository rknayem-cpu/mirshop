<%- include('partials/header') %>

<div class="max-w-2xl mx-auto bg-white p-6 my-8 shadow-md border-t-4 border-orange-600">
  <h2 class="text-xl font-bold text-gray-800 mb-6 flex items-center gap-2">
    <i class="fa-solid fa-plus-circle text-orange-600"></i> Add New Product
  </h2>

<%= status || '' %>

  <!-- Product Form -->
  <form action="/add" method="POST" class="space-y-4 text-sm text-gray-700">                                            
    <!-- Product Name -->
    <div>
      <label class="block font-medium mb-1">Product Name *</label>
      <input type="text" name="name" required class="w-full border border-gray-300 p-2 focus:outline-orange-600">
    </div>

    <!-- Bio / Description -->
    <div>
      <label class="block font-medium mb-1">Product Bio *</label>
      <textarea name="bio" required rows="3" class="w-full border border-gray-300 p-2 focus:outline-orange-600"></textarea>
    </div>

    <!-- Image URLs -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <label class="block font-medium mb-1 text-orange-600">Main Image URL *</label>
        <input type="url" name="images" required placeholder="https://..." class="w-full border border-orange-300 p-2 focus:outline-orange-600">
      </div>
      <div>
        <label class="block font-medium mb-1">Optional Image URL 2</label>
        <input type="url" name="images" placeholder="https://..." class="w-full border border-gray-300 p-2 focus:outline-orange-600">
      </div>
      <div>
        <label class="block font-medium mb-1">Optional Image URL 3</label>
        <input type="url" name="images" placeholder="https://..." class="w-full border border-gray-300 p-2 focus:outline-orange-600">
      </div>
      <div>
        <label class="block font-medium mb-1">Optional Image URL 4</label>
        <input type="url" name="images" placeholder="https://..." class="w-full border border-gray-300 p-2 focus:outline-orange-600">
      </div>
    </div>

    <!-- Category -->
    <div>
      <label class="block font-medium mb-1">Category *</label>
      <select name="category" required class="w-full border border-gray-300 p-2 bg-white focus:outline-orange-600">
        <option value="">Select Category</option>
        <option value="T-Shirt">T-Shirt</option>
        <option value="Mug">Custom Mug</option>
        <option value="ID Card">PVC ID Card</option>
        <option value="Gadgets">Gadgets</option>
      </select>
    </div>

    <!-- [FIXED] Regular Price Field -->
    <div>
      <label class="block font-medium mb-1 text-slate-950">Regular Price (৳) *</label>
      <input type="number" name="price" id="regularPrice" required placeholder="0.00" min="1" class="w-full border border-gray-300 p-2 focus:outline-orange-600">
    </div>

    <!-- Checkboxes (Discount & New Arrival) -->
    <div class="flex flex-wrap gap-6 py-2 border-y border-gray-100">
      <!-- Discount Checkbox -->
      <label class="flex items-center gap-2 cursor-pointer font-medium select-none">
        <input type="checkbox" name="isDiscount" id="isDiscount" value="true" class="w-4 h-4 accent-orange-600">
        Apply Discount?
      </label>

      <!-- New Arrival Checkbox -->
      <label class="flex items-center gap-2 cursor-pointer font-medium select-none">
        <input type="checkbox" name="isNewArrival" value="true" class="w-4 h-4 accent-orange-600">
        New Arrival?
      </label>
    </div>

    <!-- Dynamic Discount Price Field -->
    <div id="discountPriceWrapper" class="hidden transition-all duration-300">
      <label class="block font-medium mb-1 text-red-600">Discount Price (৳) *</label>
      <input type="number" name="discountPrice" id="discountPrice" placeholder="0.00" min="0" class="w-full border border-red-300 p-2 focus:outline-red-500">
      <span id="price-error" class="text-[11px] text-red-600 mt-1 hidden block">Discount price must be less than regular price.</span>
    </div>

    <!-- Submit Button -->
    <button type="submit" id="submit-btn" class="w-full bg-orange-600 hover:bg-orange-700 text-white font-bold py-2.5 transition-colors shadow-sm">
      Publish Product
    </button>

  </form>
</div>

<!-- JavaScript for Dynamic Discount & Price Validation -->
<script type="text/javascript">
  const discountCheckbox = document.querySelector('#isDiscount');
  const discountWrapper = document.querySelector('#discountPriceWrapper');
  const discountInput = document.querySelector('#discountPrice');
  const regularPriceInput = document.querySelector('#regularPrice');
  const priceError = document.querySelector('#price-error');
  const submitBtn = document.querySelector('#submit-btn');

  // ডিসকাউন্ট বক্স হ্যান্ডেলার
  discountCheckbox.addEventListener('change', function() {
    if (this.checked) {
      discountWrapper.classList.remove('hidden');
      discountInput.required = true;
    } else {
      discountWrapper.classList.add('hidden');
      discountInput.required = false;
      discountInput.value = '';
      priceError.classList.add('hidden');
      submitBtn.removeAttribute('disabled');
    }
  });

  // রিয়েল-টাইম প্রাইস ভ্যালিডেশন (অরিজিনাল প্রাইসের চেয়ে ডিসকাউন্ট বেশি দেওয়া আটকাতে)
  function validatePrices() {
    const regPrice = parseFloat(regularPriceInput.value) || 0;
    const discPrice = parseFloat(discountInput.value) || 0;

    if (discountCheckbox.checked && discPrice >= regPrice) {
      priceError.classList.remove('hidden');
      submitBtn.setAttribute('disabled', 'true');
      submitBtn.style.opacity = "0.5";
    } else {
      priceError.classList.add('hidden');
      submitBtn.removeAttribute('disabled');
      submitBtn.style.opacity = "1";
    }
  }

  discountInput.addEventListener('input', validatePrices);
  regularPriceInput.addEventListener('input', validatePrices);
</script>

<%- include('partials/footer') %>


