<div class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-orange-50/30 py-6 px-4 sm:px-6 font-sans antialiased">
  <div class="max-w-7xl mx-auto space-y-8">
    
    <!-- 🌟 Premium Header -->
    <header class="bg-white/80 backdrop-blur-sm border border-slate-200/80 rounded-2xl p-5 shadow-lg shadow-slate-200/50 flex flex-col lg:flex-row items-center justify-between gap-4 transition-all hover:shadow-xl">
      <div class="flex items-center gap-4 w-full lg:w-auto">
        <!-- Animated Brand Logo -->
        <div class="relative group">
          <div class="w-12 h-12 bg-gradient-to-br from-slate-900 to-slate-800 rounded-2xl flex items-center justify-center text-white font-black text-xl shadow-lg shadow-slate-900/20 group-hover:shadow-orange-500/30 transition-all duration-300 group-hover:scale-105">
            M
          </div>
          <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-orange-500 rounded-full border-2 border-white animate-pulse"></div>
        </div>
        
        <div>
          <h1 class="text-lg sm:text-xl font-bold tracking-tight text-slate-900">
            Mir Shop <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-orange-400">Premium</span>
          </h1>
          <p class="text-[10px] text-slate-400 font-mono uppercase tracking-widest flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            secure checkout • authentic retail
          </p>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="flex items-center gap-2 bg-slate-100/80 p-1 rounded-xl border border-slate-200/50 w-full lg:w-auto">
        <a href="/all" class="group text-[10px] font-mono font-bold uppercase tracking-wider px-4 py-2 rounded-lg text-slate-600 hover:text-slate-950 hover:bg-white transition-all duration-300 flex items-center gap-1.5">
          <i class="fa-solid fa-boxes-stacked group-hover:scale-110 transition-transform"></i>
          <span class="hidden sm:inline">All Goods</span>
        </a>
        <a href="/category" class="group text-[10px] font-mono font-bold uppercase tracking-wider px-4 py-2 rounded-lg text-slate-600 hover:text-slate-950 hover:bg-white transition-all duration-300 flex items-center gap-1.5">
          <i class="fa-solid fa-layer-group group-hover:scale-110 transition-transform"></i>
          <span class="hidden sm:inline">Categories</span>
        </a>
        <a href="/search" class="group bg-gradient-to-r from-orange-600 to-orange-500 hover:from-orange-500 hover:to-orange-400 text-white text-[10px] font-mono font-bold uppercase tracking-wider px-5 py-2 rounded-lg shadow-lg shadow-orange-500/25 transition-all duration-300 flex items-center gap-1.5 active:scale-95">
          <i class="fa-solid fa-magnifying-glass group-hover:scale-110 transition-transform"></i>
          <span>Search</span>
        </a>
      </nav>
    </header>

    <!-- ⚡ Hero Section -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
      
      <!-- Left Hero Panel -->
      <section class="lg:col-span-7 bg-white/80 backdrop-blur-sm border border-slate-200/80 rounded-3xl p-8 shadow-lg shadow-slate-200/50 relative overflow-hidden hover:shadow-xl transition-all duration-500">
        <!-- Decorative Elements -->
        <div class="absolute -top-20 -right-20 w-64 h-64 bg-orange-200/20 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-emerald-200/20 rounded-full blur-3xl"></div>
        <div class="absolute top-0 right-0 text-[120px] font-black text-slate-100/20 select-none pointer-events-none -mr-10 -mt-10">
          MIR
        </div>

        <div class="relative z-10">
          <div class="inline-flex items-center gap-2 text-[9px] font-mono font-bold uppercase tracking-widest text-orange-600 bg-orange-50 px-3 py-1.5 border border-orange-100 rounded-full mb-5">
            <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span>
            Verified Marketplace
          </div>
          
          <h2 class="text-2xl sm:text-3xl font-black text-slate-900 leading-tight">
            স্মার্ট সলিউশন ও চমৎকার
            <br class="hidden sm:block">
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-orange-400">কাস্টমাইজড প্রডাক্ট</span> কালেকশন।
          </h2>
          
          <p class="text-sm text-slate-500 mt-4 max-w-md leading-relaxed">
            আমরা দিচ্ছি সেরা কোয়ালিটির নিশ্চয়তা ও দ্রুত ডেলিভারি প্যানেল। কোনো ঝামেলা ছাড়াই অর্ডার কমপ্লিট করুন।
          </p>

          <div class="flex flex-wrap gap-3 pt-6">
            <a href="/all" class="group bg-gradient-to-r from-orange-600 to-orange-500 hover:from-orange-500 hover:to-orange-400 text-white font-mono font-bold text-[10px] px-6 py-3.5 rounded-xl shadow-lg shadow-orange-500/25 transition-all duration-300 flex items-center gap-2 active:scale-95">
              Explore Catalog
              <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </a>
            <a href="/search" class="group bg-white border border-slate-300 hover:border-orange-400 text-slate-700 font-mono font-bold text-[10px] px-6 py-3.5 rounded-xl transition-all duration-300 flex items-center gap-2 hover:shadow-md">
              <i class="fa-solid fa-magnifying-glass"></i>
              Quick Search
            </a>
          </div>
        </div>
      </section>

      <!-- Right Utility Grid -->
      <aside class="lg:col-span-5 flex flex-col gap-4">
        
        <!-- Category Card -->
        <div class="group bg-gradient-to-br from-slate-900 to-slate-800 p-5 rounded-2xl shadow-lg shadow-slate-900/20 flex items-center justify-between hover:shadow-orange-500/20 transition-all duration-500 hover:scale-[1.02]">
          <div>
            <div class="flex items-center gap-2">
              <i class="fa-solid fa-th-large text-orange-400 text-sm"></i>
              <h3 class="text-sm font-bold text-white uppercase tracking-wide">Dynamic Categories</h3>
            </div>
            <p class="text-[10px] font-mono text-slate-400 uppercase">// segment filter grid</p>
          </div>
          <a href="/category" class="w-10 h-10 bg-white/10 hover:bg-orange-500 rounded-xl flex items-center justify-center text-white transition-all duration-300 group-hover:rotate-12">
            <i class="fa-solid fa-arrow-right text-xs"></i>
          </a>
        </div>

        <!-- Search Card -->
        <div class="group bg-white border border-slate-200/80 p-5 rounded-2xl shadow-sm flex items-center justify-between hover:shadow-lg hover:border-orange-200 transition-all duration-300">
          <div>
            <div class="flex items-center gap-2">
              <i class="fa-solid fa-search text-orange-500 text-sm"></i>
              <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wide">Advanced Finder</h3>
            </div>
            <p class="text-[10px] font-mono text-slate-400 uppercase">// search filter engine</p>
          </div>
          <a href="/search" class="w-10 h-10 bg-slate-100 hover:bg-slate-900 rounded-xl flex items-center justify-center text-slate-600 hover:text-white transition-all duration-300 group-hover:rotate-12">
            <i class="fa-solid fa-arrow-right text-xs"></i>
          </a>
        </div>


<%- include('./pd') %>


        <!-- Trust Card -->
        <div class="bg-gradient-to-r from-emerald-50 to-emerald-100/50 border border-emerald-200/50 p-4 rounded-2xl flex items-center gap-4 hover:shadow-md transition-all duration-300">
          <div class="w-10 h-10 rounded-xl bg-emerald-600 text-white flex items-center justify-center shadow-lg shadow-emerald-600/20 text-sm">
            <i class="fa-solid fa-circle-check"></i>
          </div>
          <div>
            <h4 class="text-xs font-bold text-emerald-950 uppercase tracking-wide flex items-center gap-2">
              Fast Track Support
              <span class="text-[8px] bg-emerald-200 text-emerald-700 px-1.5 py-0.5 rounded-full">24/7</span>
            </h4>
            <p class="text-[9px] text-emerald-700 font-medium">২৪ ঘণ্টার নির্ভরযোগ্য কাস্টমার কেয়ার ডেলিভারি সার্ভিস।</p>
          </div>
        </div>

      </aside>

    </div>

    <!-- 📊 Stats & Features -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-2xl p-5 text-center border border-slate-200/80 shadow-sm hover:shadow-lg hover:border-orange-200 transition-all duration-300 group">
        <div class="text-2xl font-black text-orange-600
         group-hover:scale-110 
         transition-transform">1K+</div>
        <div class="text-[10px] text-slate-500 mt-1">Happy Customers</div>
      </div>
      <div class="bg-white rounded-2xl p-5 text-center border border-slate-200/80 shadow-sm hover:shadow-lg hover:border-blue-200 transition-all duration-300 group">
        <div class="text-2xl font-black text-blue-600 
        group-hover:scale-110 transition-transform">100+</div>
        <div class="text-[10px] text-slate-500 mt-1">Products</div>
      </div>
      <div class="bg-white rounded-2xl p-5 text-center border border-slate-200/80 shadow-sm hover:shadow-lg hover:border-emerald-200 transition-all duration-300 group">
        <div class="text-2xl font-black 
        text-emerald-600 group-hover:scale-110
         transition-transform">75%</div>
        <div class="text-[10px] text-slate-500 mt-1">Satisfaction</div>
      </div>
      <div class="bg-white rounded-2xl p-5 text-center border border-slate-200/80 shadow-sm hover:shadow-lg hover:border-purple-200 transition-all duration-300 group">
        <div class="text-2xl font-black
         text-purple-600 group-hover:scale-110
          transition-transform">24/7</div>
        <div class="text-[10px] text-slate-500 mt-1">Support</div>
      </div>
    </div>

  </div>
</div>