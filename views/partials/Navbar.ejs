<!-- ⚡ JAVASCRIPT CONTROLLER -->
<script type="text/javascript">
  const mob = document.querySelector("#mob");
  const overlay = document.querySelector("#sidebar-overlay");

  function openav() {
    mob.classList.remove("translate-x-full");
    overlay.classList.remove("invisible", "opacity-0");
    overlay.classList.add("opacity-100");
    document.body.style.overflow = "hidden"; // স্লাইডার অন থাকলে ব্যাকগ্রাউন্ড স্ক্রল লক
  }

  function closenav() {
    mob.classList.add("translate-x-full");
    overlay.classList.remove("opacity-100");
    overlay.classList.add("opacity-0");
    document.body.style.overflow = ""; // ক্লোজ হলে স্ক্রল নরমাল
    setTimeout(() => overlay.classList.add("invisible"), 300);
  }
</script>
